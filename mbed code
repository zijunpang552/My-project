//In addition, the other two .bin files can be directly flashed into the L432KC without any additional processing.

#include "mbed.h"
#include "SSD1306.h"
#include "MAX30102.h"
#include "my_spo2.h"
#include <cstdio>

#define BUFFER_SIZE 200  // 推荐采样数量，越多越稳

I2C i2c(PB_7, PB_6); // SDA, SCL
SSD1306 oled(i2c, 0x3C);
MAX30102 sensor(i2c);

uint32_t red_buffer[BUFFER_SIZE];
uint32_t ir_buffer[BUFFER_SIZE];

int main() {
    oled.init();
    oled.clear();
    oled.printf(0, 0, "Karina");
    oled.update();

    if (!sensor.begin()) {
        oled.clear();
        oled.printf(0, 0, "Karina");
        oled.printf(0, 16, "MAX30102 Error");
        oled.update();
        while (1);
    }

    char line[32];
    int spo2 = 0, bpm = 0;

    while (true) {
        uint32_t ir_sum = 0;

        for (int i = 0; i < BUFFER_SIZE; i++) {
            while (!sensor.readFIFO(red_buffer[i], ir_buffer[i])) {
                thread_sleep_for(5);
            }
            ir_sum += ir_buffer[i];
            thread_sleep_for(50); // 20Hz 采样
        }

        oled.clear();
        oled.printf(0, 0, "Karina");

        if (ir_sum / BUFFER_SIZE > 30000) {
            bool ok = compute_spo2_bpm(ir_buffer, red_buffer, BUFFER_SIZE, &spo2, &bpm);

            if (ok) {
                sprintf(line, "SpO2: %d%%", spo2);
                oled.printf(0, 16, line);

                sprintf(line, "BPM : %d", bpm);
                oled.printf(0, 32, line);
            } else {
                oled.printf(0, 16, "Reading...");
                oled.printf(0, 32, "Hold still");
            }
        } else {
            oled.printf(0, 16, "Please");
            oled.printf(0, 32, "Put finger");
        }

        oled.update();
    }
}
